# === 性能配置 ===
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_RETRY_MAX_ATTEMPTS=3
REDIS_RETRY_DELAY=0.1
```

### 4.2 settings.py 配置系统 (CRITICAL)

**强制结构**：
```python
# === CRITICAL: 以下结构必须严格遵守 ===

# 时区配置 (不可修改)
TZ_NY = ZoneInfo("America/New_York")

# Redis配置类 (必须存在)
class RedisConfig:
    REDIS_HOST: str = os.getenv("REDIS_HOST", "127.0.0.1")
    REDIS_PORT: int = int(os.getenv("REDIS_PORT", "6379"))
    REDIS_PASSWORD: str | None = os.getenv("REDIS_PASSWORD")
    REDIS_DB: int = int(os.getenv("REDIS_DB", "0"))
    # ... 其他配置项

# 便捷访问函数 (必须存在)
def get_redis_config() -> RedisConfig:
    return redis_config
```

### 4.3 连接池配置标准 (CRITICAL)

**强制参数配置**：
```python
# === CRITICAL: 连接池参数必须配置化 ===
CONNECTION_POOL_CONFIG = {
    'max_connections': int(os.getenv("REDIS_MAX_CONNECTIONS", "20")),
    'decode_responses': True,  # 固定值
    'socket_connect_timeout': int(os.getenv("REDIS_SOCKET_CONNECT_TIMEOUT", "10")),
    'socket_timeout': int(os.getenv("REDIS_SOCKET_TIMEOUT", "10")),
    'socket_keepalive': True,  # 固定值
    'socket_keepalive_options': {1: 60, 2: 30, 3: 3}  # 固定值
}
```

## 5. 数据操作规范

### 5.1 写入操作标准 (CRITICAL)

**实时数据写入流程**：
```python
# === CRITICAL: 实时数据写入必须遵循此流程 ===

def store_live_data(data: dict) -> bool:
    # 1. 数据验证
    validate_breadth_data(data)

    # 2. 时间戳处理 (美东时间)
    timestamp_ms = int(data['timestamp'].timestamp() * 1000)

    # 3. 批量操作
    with redis_client.pipeline() as pipe:
        # 更新最新数据
        pipe.hset('market:breadth:live', mapping=data)

        # 添加到时间序列
        pipe.zadd(f'market:breadth:series:{date_str}', {timestamp_ms: timestamp_ms})

        # 添加详细记录
        pipe.hset(f'market:breadth:record:{timestamp_ms}', mapping=data)

        # 更新元数据
        pipe.set('market:breadth:metadata:last_update', timestamp_ms)

        # 执行批量操作
        pipe.execute()

    return True
```

### 5.2 读取操作标准 (CRITICAL)

**数据查询优化**：
```python
# === CRITICAL: 数据查询必须使用批量操作 ===

def get_time_range_data(start_time: datetime, end_time: datetime) -> pd.DataFrame:
    # 1. 时间范围计算
    start_ms = int(start_time.timestamp() * 1000)
    end_ms = int(end_time.timestamp() * 1000)

    # 2. 使用pipeline批量获取
    with redis_client.pipeline() as pipe:
        for date in date_range:
            pipe.zrangebyscore(f'market:breadth:series:{date}', start_ms, end_ms)

        results = pipe.execute()

    # 3. 批量处理记录
    all_records = []
    for record_ids in results:
        if record_ids:
            # 批量获取记录数据
            records = redis_client.mget([f'market:breadth:record:{rid}' for rid in record_ids])
            all_records.extend(records)

    return process_records_to_dataframe(all_records)
```

### 5.3 数据一致性保障 (CRITICAL)

**事务和原子性**：
- ✅ **实时数据**：使用pipeline保证原子性
- ✅ **批量操作**：优先使用mget/mset而不是循环
- ✅ **错误回滚**：操作失败时自动清理不一致数据
- ✅ **数据验证**：写入前验证数据完整性

## 6. 性能优化规范

### 6.1 连接池优化 (CRITICAL)

**连接池配置标准**：
```python
# === CRITICAL: 连接池必须优化配置 ===
POOL_OPTIMIZATION = {
    'max_connections': 20,      # 根据并发需求调整
    'socket_keepalive': True,   # 启用TCP保活
    'socket_timeout': 10,       # 合理的超时时间
