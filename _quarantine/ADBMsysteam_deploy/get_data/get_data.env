# ============================================================================
# Longbridge认证信息
# ============================================================================

# Cookie信息
# LB_COOKIE=... (已在上方设置)

# ============================================================================
# Redis配置
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# 系统配置
# ============================================================================

# 数据刷新间隔(秒)
REFRESH_INTERVAL=3

# ============================================================================
# BM计算器参数 (Breadth Momentum)
# ============================================================================

# 分段权重 (非线性 1:3:9 指数权重)
# 校准依据: 10,000条真实Redis历史数据
# Tier1=小幅波动(0~3%), Tier2=中幅波动(3~5%), Tier3=大幅波动(>5%)
BM_WEIGHT_TIER1=1
BM_WEIGHT_TIER2=3
BM_WEIGHT_TIER3=9

# BM_BROAD 权重 (经验导出, Pearson r vs net_breadth, 用于Regime分类)
# 校准依据: 小幅波动(0~3%) r=0.94, 中幅(3~5%) r=0.48, 大幅(>5%) r=0.20
# 权重顺序与预测力正对齐
BM_BROAD_WEIGHT_TIER1=5
BM_BROAD_WEIGHT_TIER2=2
BM_BROAD_WEIGHT_TIER3=1

# 动态Regime阈值 - 波动率计算窗口
# 20次观测 × 3秒 = ~60秒滚动窗口，正好覆盖1分钟内状态
BM_VOL_WINDOW=20

# 波动率乘数: threshold = std * multiplier
# 校准: Redis历史BM Std=2594, 乘0.8以适度敏感
# < 1.0 = 对趋势更敏感 (更多Trend信号)
# > 1.0 = 对趋势更保守 (更多Chop信号)
BM_VOL_MULTIPLIER=0.8

# 静态回退阈值 (当历史数据不足时使用, 冷启动)
# 最终分析结论 (基于29.3万条云端历史流水):
# 新权重1:3:9下 BM Std=5027, 取0.5*Std=2500
BM_STATIC_THRESHOLD=2500
# Delta校准: 历史P50=12 (中位数跳动)
BM_STATIC_DELTA_THRESHOLD=12

# 自动启动配置
AUTO_STARTUP_ADVANCE_MINUTES=3

# 自动关闭配置
AUTO_SHUTDOWN_ENABLED=true
AUTO_SHUTDOWN_NORMAL_OFFSET_MINUTES=1

# 是否启用Google Sheets同步
GOOGLE_SYNC_ENABLED=0

# Google Sheets配置 (如果启用同步)
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_CREDENTIALS_PATH=path/to/credentials.json

# ============================================================================
# 其他配置
# ============================================================================

# 日志级别
LOG_LEVEL=INFO

# 数据输出路径
OUTPUT_PATH=./output

# ============================================================================
# Redis存储配置 (CRITICAL - 必须启用)
# ============================================================================

# 是否启用Redis存储 (true/false)
USE_REDIS=true

# 演示模式 (true=使用模拟数据, false=使用真实API)
DEMO_MODE=false

# Redis连接配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
