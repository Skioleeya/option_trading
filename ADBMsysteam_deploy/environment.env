# 美股广度监控系统 - 全局环境配置
# 包含所有组件共享的基础配置和环境标识

# =============================================================================
# 核心环境标识
# =============================================================================
ENVIRONMENT=development                # 运行环境: development/production/testing
SYSTEM_NAME=US-Market-Monitor         # 系统名称标识
VERSION=2.0.0                         # 系统版本号

# =============================================================================
# 时区和本地化配置
# =============================================================================
TIMEZONE=America/New_York             # 系统时区 (美东时间)

# =============================================================================
# 全局日志配置
# =============================================================================
LOG_LEVEL_GLOBAL=INFO                 # 全局日志级别: DEBUG/INFO/WARNING/ERROR
LOG_FORMAT=standard                   # 日志格式: standard/json/simple

# =============================================================================
# 全局性能和监控配置
# =============================================================================
HEALTH_CHECK_INTERVAL_SECONDS=60     # 健康检查间隔时间
MEMORY_WARNING_THRESHOLD_MB=1024     # 内存使用告警阈值 (MB)

# =============================================================================
# 全局网络和重试配置
# =============================================================================
REQUEST_TIMEOUT_SECONDS=30           # 默认网络请求超时时间
MAX_RETRIES=3                        # 默认重试次数
STOP_REDIS_ON_SHUTDOWN=false

# =============================================================================
# 安全认证配置 (Authentication)
# =============================================================================
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=ZKL135588176578
# 生产环境请务必修改以下密钥
FLASK_SECRET_KEY=change_this_to_a_random_string_in_production

# =============================================================================
# 组件专用配置位置说明：
# =============================================================================
# - 数据采集器: get_data/get_data.env
# - 监控面板: monitor/monitor.env
#
# 此文件专注于全局共享的基础配置
