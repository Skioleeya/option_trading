{
  "version": "2026-03-06",
  "description": "Layer anti-coupling guardrails for strict session validation.",
  "rules": [
    {
      "id": "L2_NO_IMPORT_L3",
      "enabled": true,
      "glob": "l2_decision/*.py",
      "regex": "^\\s*(from|import)\\s+l3_assembly\\b",
      "message": "L2 must not import L3 implementation modules."
    },
    {
      "id": "L2_NO_IMPORT_L4",
      "enabled": true,
      "glob": "l2_decision/*.py",
      "regex": "^\\s*(from|import)\\s+l4_ui\\b",
      "message": "L2 must not import L4 modules."
    },
    {
      "id": "L3_NO_IMPORT_L4",
      "enabled": true,
      "glob": "l3_assembly/*.py",
      "regex": "^\\s*(from|import)\\s+l4_ui\\b",
      "message": "L3 must not import L4 modules."
    },
    {
      "id": "L3_UI_NO_IMPORT_L2_SIGNALS_AGENTS",
      "enabled": true,
      "glob": "l3_assembly/presenters/ui/*.py",
      "regex": "^\\s*(from|import)\\s+l2_decision\\.(signals|agents)\\b",
      "message": "L3 UI presenters must not import L2 signal/agent implementations."
    },
    {
      "id": "L3_UI_NO_IMPORT_L1_ANALYSIS_TRACKERS",
      "enabled": true,
      "glob": "l3_assembly/presenters/ui/*.py",
      "regex": "^\\s*(from|import)\\s+l1_compute\\.(analysis|trackers)\\b",
      "message": "L3 UI presenters must not import L1 analysis/tracker implementations."
    },
    {
      "id": "APP_LOOPS_NO_PRIVATE_CROSS_LAYER_ACCESS",
      "enabled": true,
      "glob": "app/loops/*.py",
      "regex": "\\._[a-zA-Z]\\w*",
      "message": "app loops must not reach across layers via private members."
    }
  ],
  "allow": [
    {
      "id": "L3_ALLOW_L2_EVENTS",
      "glob": "l3_assembly/*.py",
      "regex": "^\\s*(from|import)\\s+l2_decision\\.events\\b"
    },
    {
      "id": "L2_ALLOW_L1_OUTPUT_CONTRACT",
      "glob": "l2_decision/*.py",
      "regex": "^\\s*(from|import)\\s+l1_compute\\.output\\.enriched_snapshot\\b"
    }
  ]
}
