{
  "version": "2026-03-13",
  "description": "Layer anti-coupling guardrails for strict session validation.",
  "rules": [
    {
      "id": "L0_NO_IMPORT_L2_L3_L4",
      "enabled": true,
      "glob": "l0_ingest/*.py",
      "regex": "^\\s*(from|import)\\s+l[234]_(decision|assembly|ui)\\b",
      "message": "L0 must not import L2/L3/L4 modules."
    },
    {
      "id": "L1_NO_IMPORT_L3_L4",
      "enabled": true,
      "glob": "l1_compute/*.py",
      "regex": "^\\s*(from|import)\\s+l[34]_(assembly|ui)\\b",
      "message": "L1 must not import L3/L4 modules."
    },
    {
      "id": "L2_NO_IMPORT_L3",
      "enabled": true,
      "glob": "l2_decision/*.py",
      "regex": "^\\s*(from|import)\\s+l3_assembly\\b",
      "message": "L2 must not import L3 implementation modules."
    },
    {
      "id": "L2_NO_IMPORT_L4",
      "enabled": true,
      "glob": "l2_decision/*.py",
      "regex": "^\\s*(from|import)\\s+l4_ui\\b",
      "message": "L2 must not import L4 modules."
    },
    {
      "id": "L3_NO_IMPORT_L4",
      "enabled": true,
      "glob": "l3_assembly/*.py",
      "regex": "^\\s*(from|import)\\s+l4_ui\\b",
      "message": "L3 must not import L4 modules."
    },
    {
      "id": "L3_NO_IMPORT_L2_SIGNALS_AGENTS",
      "enabled": true,
      "glob": "l3_assembly/*.py",
      "regex": "^\\s*(from|import)\\s+l2_decision\\.(signals|agents)\\b",
      "message": "L3 may import l2_decision.events only; L2 signals/agents imports are forbidden."
    },
    {
      "id": "L3_UI_NO_IMPORT_L2_SIGNALS_AGENTS",
      "enabled": true,
      "glob": "l3_assembly/presenters/ui/*.py",
      "regex": "^\\s*(from|import)\\s+l2_decision\\.(signals|agents)\\b",
      "message": "L3 UI presenters must not import L2 signal/agent implementations."
    },
    {
      "id": "L3_UI_NO_IMPORT_L1_ANALYSIS_TRACKERS",
      "enabled": true,
      "glob": "l3_assembly/presenters/ui/*.py",
      "regex": "^\\s*(from|import)\\s+l1_compute\\.(analysis|trackers)\\b",
      "message": "L3 UI presenters must not import L1 analysis/tracker implementations."
    },
    {
      "id": "L3_ASSEMBLY_NO_IMPORT_L1_ANALYSIS_TRACKERS",
      "enabled": true,
      "glob": "l3_assembly/assembly/*.py",
      "regex": "^\\s*(from|import)\\s+l1_compute\\.(analysis|trackers)\\b",
      "message": "L3 assembly modules must consume L1 contracts, not L1 analysis/tracker implementations."
    },
    {
      "id": "L2_SERVICES_NO_IMPORT_L1_ANALYSIS",
      "enabled": true,
      "glob": "l2_decision/agents/services/*.py",
      "regex": "^\\s*(from|import)\\s+l1_compute\\.analysis\\b",
      "message": "L2 service modules must not import L1 analysis implementations."
    },
    {
      "id": "APP_LOOPS_NO_PRIVATE_CROSS_LAYER_ACCESS",
      "enabled": true,
      "glob": "app/loops/*.py",
      "regex": "\\b(?:ctr|container)\\.[A-Za-z]\\w*\\._[a-zA-Z]\\w*",
      "message": "app loops must not reach across layers via private members."
    },
    {
      "id": "RUNTIME_NO_WILDCARD_IMPORT",
      "enabled": true,
      "glob": "*.py",
      "regex": "^\\s*from\\s+[^\\s]+\\s+import\\s+\\*\\s*$",
      "message": "Wildcard imports are forbidden in runtime code."
    }
  ],
  "allow": [
    {
      "id": "L3_ALLOW_L2_EVENTS",
      "glob": "l3_assembly/*.py",
      "regex": "^\\s*(from|import)\\s+l2_decision\\.events\\b"
    },
    {
      "id": "L2_ALLOW_L1_OUTPUT_CONTRACT",
      "glob": "l2_decision/*.py",
      "regex": "^\\s*(from|import)\\s+l1_compute\\.output\\.enriched_snapshot\\b"
    }
  ]
}
